# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# API Configuration (For Edge Functions / Mock Providers)
# AI Provider (e.g., OpenAI, Anthropic, Gemini) - to be used in Supabase Edge Functions
SUPABASE_AI_API_KEY=your_ai_api_key
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-server-side-only
GEMINI_API_KEY=your-gemini-api-key-server-side-only
GEMINI_MODEL=gemini-1.5-flash
PRICE_ALERT_WORKER_SECRET=change-me-for-scheduled-worker-calls

# Third-Party Integrations (mock/partner data keys if necessary)
# Default currency is INR
DEFAULT_CURRENCY=INR
